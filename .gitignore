# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# base de données locale (dev) — ne pas pousser, contient des données de test
/prisma/*.db
/prisma/*.db-journal
/dev.db
/dev.db-journal

# PDF signés archivés localement — données utilisateurs, jamais sur git
/storage/uploads/*
!/storage/uploads/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
