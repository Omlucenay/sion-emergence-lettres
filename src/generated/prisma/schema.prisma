// Prisma schema — Sion Émergence — Lettres d'intention
// Provider: MySQL (o2switch). Pour repasser en SQLite pour un dev local,
// changer provider="sqlite" + DATABASE_URL="file:./dev.db" et lancer
// `npx prisma db push`.

generator client {
  provider      = "prisma-client-js"
  // Sortie dans le repo (commitée) — évite de relancer "prisma generate"
  // sur o2switch où WebAssembly épuise la mémoire.
  output        = "../src/generated/prisma"
  // Binaires : "native" pour le dev local, "debian-openssl-3.0.x" pour o2switch.
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Submission {
  id     String @id @default(cuid())
  type   String @db.VarChar(40)
  status String @default("pending") @db.VarChar(20)

  // Données du formulaire (JSON sérialisé) — peut être long
  formData String @db.Text

  // Signature électronique
  signatureSvg  String?   @db.MediumText
  signatureName String?   @db.VarChar(120)
  signedAt      DateTime?
  signerIp      String?   @db.VarChar(64)
  signerUa      String?   @db.VarChar(500)
  pdfHash       String?   @db.VarChar(64)
  pdfPath       String?   @db.VarChar(500)

  acceptRgpd  Boolean @default(false)
  acceptTerms Boolean @default(false)

  signerEmail String    @db.VarChar(180)
  emailSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
