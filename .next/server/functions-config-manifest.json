{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin(?:\\/((?:[^\\/#\\?]+?)(?:\\/(?:[^\\/#\\?]+?))*))?(\\.json)?[\\/#\\?]?$",
          "originalSource": "/admin/:path*"
        }
      ]
    },
    "/api/pdf/[id]": {},
    "/api/pdf/[id]/preview": {},
    "/api/sign/[id]": {}
  }
}