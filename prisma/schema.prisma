// Prisma schema — Sion Émergence — Lettres d'intention
// Provider: SQLite en dev local, MySQL en prod (o2switch)
// Pour passer en MySQL: changer provider="mysql" et DATABASE_URL=mysql://...

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id            String    @id @default(cuid())
  type          String    // "academy" | "joy_club" | "partner_institutional" | "partner_professional" | "partner_economic"
  status        String    @default("pending") // "pending" | "signed" | "sent"

  // Données du formulaire (JSON sérialisé)
  formData      String    // JSON

  // Signature électronique
  signatureSvg  String?   // SVG du tracé manuscrit
  signatureName String?   // Nom du signataire confirmé
  signedAt      DateTime?
  signerIp      String?
  signerUa      String?   // user-agent
  pdfHash       String?   // SHA-256 du PDF signé
  pdfPath       String?   // Chemin du PDF archivé

  // Consentements
  acceptRgpd    Boolean   @default(false)
  acceptTerms   Boolean   @default(false)

  // Email
  signerEmail   String
  emailSentAt   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
